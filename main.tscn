[sub_resource type="GDScript" id="GDScript_1bvp3"]
script/source = "extends TextureRect

@export var glyphs: InputGlyphs

func _input(event: InputEvent) -> void:
	if event is InputEventKey:
		texture = glyphs.keyboard_icon
	elif event is InputEventJoypadButton or event is InputEventJoypadMotion:
		texture = glyphs.gamepad_icon
"

[sub_resource type="GDScript" id="GDScript_lquwl"]
script/source = "extends TextureRect

@export var glyphs: InputGlyphs

func _ready() -> void:
	texture = glyphs.kb_default
	pivot_offset = size / 2
	
	
func _input(event: InputEvent) -> void:
	if not event.is_pressed() or event.is_echo():
		return
		
	if event is InputEventKey:
		if event.is_action_pressed(\"ui_left\") or event.is_action_pressed(\"custom_ui_left\"):
			texture = glyphs.kb_left
		elif event.is_action_pressed(\"ui_right\") or event.is_action_pressed(\"custom_ui_right\"):
			texture = glyphs.kb_right
		elif event.is_action_pressed(\"ui_down\") or event.is_action_pressed(\"custom_ui_down\"):
			texture = glyphs.kb_down
		elif event.is_action_pressed(\"ui_up\") or event.is_action_pressed(\"custom_ui_up\"):
			texture = glyphs.kb_up
		else:
			return
			
	elif event is InputEventJoypadButton or event is InputEventJoypadMotion:
		if event.is_action_pressed(\"ui_left\") or event.is_action_pressed(\"custom_ui_left\"):
			texture = glyphs.pad_left
		elif event.is_action_pressed(\"ui_right\") or event.is_action_pressed(\"custom_ui_right\"):
			texture = glyphs.pad_right
		elif event.is_action_pressed(\"ui_down\") or event.is_action_pressed(\"custom_ui_down\"):
			texture = glyphs.pad_down
		elif event.is_action_pressed(\"ui_up\") or event.is_action_pressed(\"custom_ui_up\"):
			texture = glyphs.pad_up
		else:
			return
		
	blink()


func blink() -> void:
	var tween = create_tween().set_parallel(true)
	scale = Vector2(1.2, 1.2)
	modulate = Color(2, 2, 2)
	tween.tween_property(self, \"scale\", Vector2.ONE, 0.1)
	tween.tween_property(self, \"modulate\", Color.WHITE, 0.1)
"

